# ============================================================
# SecureBank Platform — Environment Variables Template
# NEVER commit real values. Copy to .env and fill in.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://securebank:CHANGE_ME@localhost:5432/securebank?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT (RS256 Asymmetric) ---
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=securebank-platform

# --- Encryption (AES-256) ---
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX_KEY_HERE_00
ENCRYPTION_IV_LENGTH=16

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=12

# --- Rate Limiting ---
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5

# --- MFA (TOTP) ---
MFA_ISSUER=SecureBank
MFA_ALGORITHM=sha1
MFA_DIGITS=6
MFA_PERIOD=30

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=securebank-api
KAFKA_GROUP_ID=securebank-consumers

# --- Account Lockout ---
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=30

# --- Transaction Limits ---
TRANSFER_MFA_THRESHOLD=1000
DAILY_TRANSFER_LIMIT_SEPA=10000
MONTHLY_TRANSFER_LIMIT_SEPA=50000
DAILY_TRANSFER_LIMIT_SWIFT=25000

# --- Beneficiary ---
BENEFICIARY_QUARANTINE_HOURS=72
MAX_BENEFICIARIES_PER_CLIENT=20

# --- Fraud Detection ---
FRAUD_SCORE_THRESHOLD=0.75

# --- Notification ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMS_PROVIDER_API_KEY=CHANGE_ME

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=json
